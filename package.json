{
  "name": "video-processing",
  "version": "0.1.0+alpha.1",
  "description": "Video processing service using FFmpeg",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prod": "NODE_ENV=production pnpm run build && pnpm run start",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop video-processing",
    "pm2:restart": "pm2 restart video-processing",
    "pm2:logs": "pm2 logs video-processing",
    "deploy:setup": "chmod +x scripts/setup-ubuntu-server.sh && ./scripts/setup-ubuntu-server.sh",
    "deploy": "chmod +x scripts/deploy-manual.sh && ./scripts/deploy-manual.sh",
    "docker:build": "docker build -t video-processing .",
    "docker:run": "docker run -p 3000:3000 video-processing",
    "docker:compose": "docker-compose up -d",
    "health": "curl -f http://localhost:3000/api/health || exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@antfu/eslint-config": "^4.6.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@nuxt/eslint": "^1.1.0",
    "archiver": "^7.0.1",
    "assemblyai": "^4.9.0",
    "eslint": "^9.21.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "nuxt": "^3.13.0",
    "zod": "^3.24.2"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "win32",
        "darwin",
        "current"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    },
    "ignoredBuiltDependencies": [
      "ffmpeg-static"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/archiver": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13"
  }
}
