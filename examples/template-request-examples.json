        }
      },
      "POST": {
        "description": "Process video with template",
        "required_fields": ["url", "srtContent", "templateName"],
        "optional_fields": ["outputName", "options"],
        "response": "Video file stream (MP4)"
      }
    }
  },
  
  "curl_examples": {
